{
  "manifest_version": 3,
  "name": "MeetScribe",
  "version": "1.0",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "identity",
    "tabs",
    "notifications"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
